# OpenRouter API 配置
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.4
OPENROUTER_SEARCH_MODEL=perplexity/sonar
TAVILY_API_KEY=

# 搜索配置
SEARCH_PROVIDER=mcp
SEARCH_MAX_RESULTS=10

# MCP 配置
MCP_SERVER_URL=http://127.0.0.1:8000
MCP_SERVER_COMMAND=
MCP_SERVER_ARGS=
MCP_API_KEY=
MCP_SEARCH_TOOL=web_search
MCP_FETCH_TOOL=fetch_url
MCP_TIMEOUT=30
MCP_TRANSPORT=http

# 论文生成配置
TARGET_WORD_COUNT=1900
WORD_COUNT_TOLERANCE=200
MAX_ITERATIONS=3
MIN_QUALITY_SCORE=8.0

# 缓存配置
CACHE_DIR=./cache
CACHE_EXPIRE_DAYS=7

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/mcp_paper_agent.log
